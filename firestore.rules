rules_version = '2';
// כללי גישה לנתונים (Firestore).
// כל משתתף ניגש רק לתיקייה שלו. חברי ועדה (לפי כתובת מייל) ניגשים להכול.
// >>> עדכנו את רשימת כתובות המייל של חברי הוועדה כאן וגם בקובץ storage.rules <<<
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email_verified == true &&
        request.auth.token.email in [
          'jude@excelleader.co.il'
        ];
    }

    match /participants/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());

      match /{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }
    }

    // counter for the sequential process number (IBCA-2026-001 ...)
    match /counters/{doc} {
      allow read, write: if request.auth != null;
    }

    // registry: committee pre-registers members and assigns numbers.
    // a member may read only their own entry (to claim their number on first login).
    match /registry/{emailId} {
      allow get: if request.auth != null &&
        (isAdmin() || resource == null || resource.data.email == request.auth.token.email);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // approvals: only the committee writes; a member may read their own (to download the certificate).
    match /approvals/{uid} {
      allow get: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
