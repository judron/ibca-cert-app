rules_version = '2';
// כללי גישה לקבצים (Storage).
// כל משתתף ניגש רק לתיקייה שלו. חברי ועדה (לפי כתובת מייל) ניגשים להכול.
// >>> עדכנו את רשימת כתובות המייל של חברי הוועדה כאן וגם בקובץ firestore.rules <<<
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email_verified == true &&
        request.auth.token.email in [
          'jude@excelleader.co.il'
        ];
    }

    match /participants/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }
  }
}
